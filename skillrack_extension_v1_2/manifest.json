{
  "manifest_version": 2,
  "name": "SkillRack extension",
  "version": "1.2",
  "description": "SkillRack extension v1.2 — ACE injection runs in page context and returns result.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "SkillRack extension"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon-48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "skillrack@local"
    }
  }
}

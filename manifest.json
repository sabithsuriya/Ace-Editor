{
  "manifest_version": 2,
  "name": "SkillRack extension",
  "version": "1.3",
  "description": "SkillRack extension v1.3 — ACE injection with Force Copy functionality.",
  "default_locale": "en",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "webRequest",
    "https://*/*",
    "http://*/*"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "SkillRack extension",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "rZ7agds0y5.js",
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "icons": {
    "48": "icons/icon-48.png"
  }
}
